<Window x:Class="DPI_Home.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:models="clr-namespace:DPI_Home.Models"
        xmlns:viewmodels="clr-namespace:DPI_Home.ViewModels"
        Title="DPI Home — MikroTik Traffic Analyzer"
        Height="900" Width="1400"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A2E"
        TextElement.Foreground="White"
        FontFamily="Segoe UI, sans-serif">

    <Window.DataContext>
        <viewmodels:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="AlertCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#16213E"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2A2A4A"/>
        </Style>
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#90CAF9"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== HEADER ===== -->
        <!-- Two explicit Grid.Row lines instead of a WrapPanel inside a Width="Auto" column:
             an Auto-sized column gives its content "infinite" width during Measure, so a
             WrapPanel there never wraps in the Measure pass — the Grid then reserves too
             little height for it, and whatever content actually wraps at Arrange time gets
             clipped by the row below. A Grid.Row always has a finite width from its parent,
             so a WrapPanel placed there measures and wraps correctly. -->
        <Border Grid.Row="0" Background="#0F3460" Padding="16,10" BorderBrush="#1A5276" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 0: logo + status/start-stop -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🛡️" FontSize="28" Margin="0,0,12,0"/>
                        <StackPanel>
                            <TextBlock Text="DPI Home" FontSize="22" FontWeight="Bold" Foreground="#E8EAF6"/>
                            <TextBlock Text="MikroTik Traffic Analyzer" FontSize="12" Foreground="#90CAF9" Margin="0,-2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,16,0" VerticalAlignment="Center">
                            <Ellipse Width="10" Height="10" Fill="{Binding StatusColor}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ConnectionStatus}" FontSize="13" Foreground="#B0BEC5" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center"
                                    ToolTip="Agent API status — tools: dpi_status, dpi_alerts, dpi_blocks, dpi_unblock">
                            <Ellipse Width="8" Height="8" Margin="0,0,5,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#FF9800"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ApiConnected}" Value="True">
                                                <Setter Property="Fill" Value="#4CAF50"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="API" FontSize="12" Foreground="#78909C" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Border Background="#1A1A2E" CornerRadius="6" BorderBrush="#2A2A4A" BorderThickness="1" Padding="8,4" Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Port:" FontSize="12" Foreground="#78909C" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding ListenPort}" FontSize="13" Foreground="#64B5F6" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Button Command="{Binding StartCommand}" Width="140" Height="36"
                                materialDesign:ButtonAssist.CornerRadius="8" FontWeight="SemiBold" FontSize="13">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                    <Setter Property="Background" Value="#4CAF50"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Content" Value="▶ Start"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Background" Value="#F44336"/>
                                            <Setter Property="Content" Value="■ Stop"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Row 1: configuration controls — wraps to as many lines as needed, correctly -->
                <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                    <Border Background="#1A1A2E" CornerRadius="6" BorderBrush="#2A2A4A" BorderThickness="1" Padding="8,4" Margin="0,4,8,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="MikroTik:" FontSize="12" Foreground="#78909C" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox Text="{Binding MikrotikHost}" Width="90" FontSize="12"
                                     Background="#0D1B2A" Foreground="White" BorderThickness="0"
                                     materialDesign:HintAssist.Hint="IP"/>
                            <TextBlock Text=":" FontSize="12" Foreground="#78909C" VerticalAlignment="Center" Margin="2,0"/>
                            <TextBox Text="{Binding MikrotikUser}" Width="50" FontSize="12"
                                     Background="#0D1B2A" Foreground="White" BorderThickness="0"
                                     materialDesign:HintAssist.Hint="user" Margin="2,0"/>
                            <TextBox Text="{Binding MikrotikPassword}" Width="70" FontSize="12"
                                     Background="#0D1B2A" Foreground="White" BorderThickness="0"
                                     materialDesign:HintAssist.Hint="pass" Margin="2,0"/>
                            <Button Command="{Binding ConnectMikrotikCommand}"
                                    Width="112" Height="28" FontSize="11" FontWeight="SemiBold"
                                    Background="#37474F" Foreground="White"
                                    materialDesign:ButtonAssist.CornerRadius="4"
                                    Margin="6,0,0,0" Cursor="Hand"
                                    ToolTip="Connect to MikroTik API">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                        <Setter Property="Content" Value="🔗 Connect"/>
                                        <Setter Property="Background" Value="#37474F"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding MikrotikConnected}" Value="True">
                                                <Setter Property="Content" Value="✅ Connected"/>
                                                <Setter Property="Background" Value="#2E7D32"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border Background="#1A1A2E" CornerRadius="6" BorderBrush="#2A2A4A" BorderThickness="1" Padding="8,4" Margin="0,4,8,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="WAN IP:" FontSize="12" Foreground="#78909C" VerticalAlignment="Center" Margin="0,0,6,0"
                                       ToolTip="Router public address. Without it, inbound attacks on your WAN-IP are not detected (Direction=Unknown). Auto-detected on MikroTik connect (IP Cloud) or enter manually."/>
                            <TextBox Text="{Binding WanIp, UpdateSourceTrigger=PropertyChanged}" Width="100" FontSize="12"
                                     Background="#0D1B2A" Foreground="White" BorderThickness="0"
                                     materialDesign:HintAssist.Hint="e.g. 203.0.113.7"/>
                            <Button Command="{Binding ApplyWanIpCommand}"
                                    Content="✔" Width="28" Height="24" FontSize="13"
                                    Background="#37474F" Foreground="#66BB6A"
                                    materialDesign:ButtonAssist.CornerRadius="4"
                                    Margin="4,0,0,0" Cursor="Hand"
                                    ToolTip="Apply WAN IP manually"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#1A1A2E" CornerRadius="6" BorderBrush="#2A2A4A" BorderThickness="1" Padding="8,4" Margin="0,4,8,4">
                        <StackPanel Orientation="Horizontal">
                            <CheckBox IsChecked="{Binding AutoBlockEnabled}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Auto-block" FontSize="12" Foreground="#B0BEC5" VerticalAlignment="Center"
                                       ToolTip="Automatically add IPs from Critical/High alerts to DPI-Home-Blocked address-list on MikroTik. Spoofed SYN Flood IPs are skipped — SrcIp is unreliable."/>
                        </StackPanel>
                    </Border>

                    <Border Background="#1A1A2E" CornerRadius="6" BorderBrush="#2A2A4A" BorderThickness="1" Padding="8,4" Margin="0,4,8,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="RDP:" FontSize="12" Foreground="#78909C" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox Text="{Binding RdpThreshold, UpdateSourceTrigger=PropertyChanged}" Width="28" FontSize="12"
                                     Background="#0D1B2A" Foreground="White" BorderThickness="0" VerticalAlignment="Center"
                                     materialDesign:HintAssist.Hint="N"/>
                            <TextBlock Text="conn. in" FontSize="12" Foreground="#78909C" VerticalAlignment="Center" Margin="6,0,4,0"/>
                            <TextBox Text="{Binding RdpWindowMinutes, UpdateSourceTrigger=PropertyChanged}" Width="28" FontSize="12"
                                     Background="#0D1B2A" Foreground="White" BorderThickness="0" VerticalAlignment="Center"
                                     materialDesign:HintAssist.Hint="min"/>
                            <TextBlock Text="min" FontSize="12" Foreground="#78909C" VerticalAlignment="Center" Margin="2,0,0,0"
                                       ToolTip="Block IP after N new TCP connections to port 3389 within the specified time. Values are saved to settings.json."/>
                        </StackPanel>
                    </Border>

                    <Button Command="{Binding OpenDebugLogCommand}"
                            Content="📄 Log" Width="70" Height="28" FontSize="11"
                            Background="#37474F" Foreground="#B0BEC5"
                            materialDesign:ButtonAssist.CornerRadius="6"
                            Margin="0,4,8,4" Cursor="Hand"
                            ToolTip="Open detailed log — MikroTik HTTP exchange and raw syslog lines — for diagnostics if rules/blocks don't appear on the router, or to see what a syslog source actually sends"/>

                    <Border Background="#1A1A2E" CornerRadius="6" BorderBrush="#2A2A4A" BorderThickness="1" Padding="8,4" Margin="0,4,8,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Excl. ports:" FontSize="12" Foreground="#78909C" VerticalAlignment="Center" Margin="0,0,6,0"
                                       ToolTip="Ports excluded from SYN Flood / Port Scan detection — e.g. a torrent client's listening port, whose swarm traffic (many peers, one fixed port) otherwise looks like a flood."/>
                            <TextBox Text="{Binding ExcludedPortsText, UpdateSourceTrigger=PropertyChanged}" Width="90" FontSize="12"
                                     Background="#0D1B2A" Foreground="White" BorderThickness="0"
                                     materialDesign:HintAssist.Hint="e.g. 20135"/>
                            <Button Command="{Binding ApplyExcludedPortsCommand}"
                                    Content="✔" Width="28" Height="24" FontSize="13"
                                    Background="#37474F" Foreground="#66BB6A"
                                    materialDesign:ButtonAssist.CornerRadius="4"
                                    Margin="4,0,0,0" Cursor="Hand"
                                    ToolTip="Apply excluded ports"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#1A1A2E" CornerRadius="6" BorderBrush="#2A2A4A" BorderThickness="1" Padding="8,4" Margin="0,4,8,4">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#607D8B"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SyslogListening}" Value="True">
                                                <Setter Property="Fill" Value="#4CAF50"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <CheckBox IsChecked="{Binding SyslogEnabled}" VerticalAlignment="Center" Margin="0,0,6,0"
                                      ToolTip="Receive syslog from a reverse proxy (e.g. Kerio Control) to spot credential/exploit probing hidden inside encrypted HTTPS — packet analysis alone can't see it."/>
                            <TextBlock Text="Syslog UDP:" FontSize="12" Foreground="#78909C" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox Text="{Binding SyslogPortText, UpdateSourceTrigger=PropertyChanged}" Width="50" FontSize="12"
                                     Background="#0D1B2A" Foreground="White" BorderThickness="0"
                                     materialDesign:HintAssist.Hint="5140"/>
                            <Button Command="{Binding ApplySyslogSettingsCommand}"
                                    Content="✔" Width="28" Height="24" FontSize="13"
                                    Background="#37474F" Foreground="#66BB6A"
                                    materialDesign:ButtonAssist.CornerRadius="4"
                                    Margin="4,0,0,0" Cursor="Hand"
                                    ToolTip="Apply syslog port (restarts the listener if enabled)"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#1A1A2E" CornerRadius="6" BorderBrush="#2A2A4A" BorderThickness="1" Padding="8,4" Margin="0,4,0,4"
                            ToolTip="Agent API key — use header X-API-Key when calling http://127.0.0.1:37409">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔑" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="{Binding AgentApiKey}" FontSize="10" Foreground="#66BB6A" FontFamily="Consolas" VerticalAlignment="Center" MaxWidth="160" TextTrimming="CharacterEllipsis"/>
                            <Button Command="{Binding CopyApiKeyCommand}"
                                    Content="📋" Width="24" Height="22" FontSize="11"
                                    Background="#37474F" Foreground="White"
                                    materialDesign:ButtonAssist.CornerRadius="4"
                                    Margin="6,0,0,0" Padding="0" Cursor="Hand"
                                    ToolTip="Copy API key to clipboard"/>
                        </StackPanel>
                    </Border>
                </WrapPanel>
            </Grid>
        </Border>

        <!-- ===== STATS ===== -->
        <Border Grid.Row="1" Background="#16213E" Padding="16,12" BorderBrush="#1A1A2E" BorderThickness="0,0,0,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource StatCardStyle}" Margin="0,0,4,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="📦" FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Stats.TotalPackets, StringFormat={}{0:N0}}" FontSize="20" FontWeight="Bold" Foreground="#64B5F6" HorizontalAlignment="Center"/>
                        <TextBlock Text="Packets" FontSize="10" Foreground="#78909C" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource StatCardStyle}" Margin="4,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="💀" FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Stats.AlertsCritical}" FontSize="20" FontWeight="Bold" Foreground="#F44336" HorizontalAlignment="Center"/>
                        <TextBlock Text="Critical" FontSize="10" Foreground="#78909C" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource StatCardStyle}" Margin="4,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="🔴" FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Stats.AlertsHigh}" FontSize="20" FontWeight="Bold" Foreground="#FF5722" HorizontalAlignment="Center"/>
                        <TextBlock Text="High" FontSize="10" Foreground="#78909C" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Style="{StaticResource StatCardStyle}" Margin="4,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="⚡" FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Stats.AlertsMedium}" FontSize="20" FontWeight="Bold" Foreground="#FF9800" HorizontalAlignment="Center"/>
                        <TextBlock Text="Medium" FontSize="10" Foreground="#78909C" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="4" Style="{StaticResource StatCardStyle}" Margin="4,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="🚨" FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Stats.AlertsToday}" FontSize="20" FontWeight="Bold" Foreground="#E040FB" HorizontalAlignment="Center"/>
                        <TextBlock Text="Alerts" FontSize="10" Foreground="#78909C" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="5" Style="{StaticResource StatCardStyle}" Margin="4,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="🔒" FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding HttpsServerCount}" FontSize="20" FontWeight="Bold" Foreground="#66BB6A" HorizontalAlignment="Center"/>
                        <TextBlock Text="HTTPS Clients" FontSize="10" Foreground="#78909C" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="6" Style="{StaticResource StatCardStyle}" Margin="4,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="✅" FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding HttpsEstablishedCount}" FontSize="20" FontWeight="Bold" Foreground="#4CAF50" HorizontalAlignment="Center"/>
                        <TextBlock Text="Established" FontSize="10" Foreground="#78909C" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="7" Style="{StaticResource StatCardStyle}" Margin="4,0,0,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock FontSize="18" HorizontalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="⏹️"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Text" Value="🟢"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="Status" FontSize="10" Foreground="#78909C" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding ConnectionStatus}" FontSize="10" Foreground="#B0BEC5" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ===== MAIN CONTENT ===== -->
        <Grid Grid.Row="2" Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="400"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Alert Log -->
            <Border Grid.Column="0" Background="#1A1A2E" Margin="0,0,1,0">
                <Grid Margin="16,12,8,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="📋 Event Feed" Style="{StaticResource SectionHeaderStyle}" Margin="0"/>
                        <Button Grid.Column="1" Command="{Binding ClearLogCommand}"
                                Content="🗑 Clear" FontSize="11" Height="28" Width="90"
                                Background="#37474F" Foreground="#B0BEC5"
                                BorderBrush="#546E7A" BorderThickness="1"
                                materialDesign:ButtonAssist.CornerRadius="6" Cursor="Hand"/>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding AlertGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:AlertGroup}">
                                    <Border Style="{StaticResource AlertCardStyle}" BorderBrush="{Binding LevelColor}">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding LevelColor}" Opacity="0.08"/>
                                        </Border.Background>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="36"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="{Binding LevelIcon}" FontSize="20" VerticalAlignment="Top" Margin="0,2,0,0"/>

                                            <StackPanel Grid.Column="1" Margin="8,0">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <TextBlock Text="{Binding SrcIp}" FontWeight="SemiBold" FontSize="14" Foreground="White"/>
                                                    <Border Background="{Binding LevelColor}" CornerRadius="4" Padding="6,1" Margin="8,0,0,0">
                                                        <TextBlock Text="{Binding MaxLevel}" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                                    </Border>
                                                    <Border Background="#37474F" CornerRadius="4" Padding="6,1" Margin="4,0,0,0">
                                                        <TextBlock Text="{Binding CountLabel}" FontSize="10" Foreground="#B0BEC5"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding AttackTypes}" FontSize="12" Foreground="#B0BEC5" TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" VerticalAlignment="Top" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding TimeRange}" FontSize="10" Foreground="#546E7A" TextAlignment="Right"/>
                                                <Button Command="{Binding DataContext.BlockIpCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding SrcIp}"
                                                        Content="🚫 Block" Width="60" Height="22" FontSize="9"
                                                        Background="#37474F" Foreground="#FF5722"
                                                        BorderThickness="0" Cursor="Hand" Margin="0,4,0,0"
                                                        materialDesign:ButtonAssist.CornerRadius="4"
                                                        ToolTip="Block this IP on MikroTik for 24h"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- RIGHT: HTTPS Connections -->
            <Border Grid.Column="1" Background="#16213E" BorderBrush="#1A1A2E" BorderThickness="1,0,0,0">
                <Grid Margin="12,12,16,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="🔒 HTTPS Connections (port 443)" Style="{StaticResource SectionHeaderStyle}"/>

                    <Border Grid.Row="1" Background="#0D1B2A" CornerRadius="8" Padding="10" Margin="0,0,0,8" BorderBrush="#2A2A4A" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding HttpsServerCount}" FontSize="18" FontWeight="Bold" Foreground="#66BB6A" HorizontalAlignment="Center"/>
                                <TextBlock Text="Clients" FontSize="10" Foreground="#78909C" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding HttpsEstablishedCount}" FontSize="18" FontWeight="Bold" Foreground="#4CAF50" HorizontalAlignment="Center"/>
                                <TextBlock Text="Established" FontSize="10" Foreground="#78909C" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding HttpsSynFloodCount}" FontSize="18" FontWeight="Bold" Foreground="#F44336" HorizontalAlignment="Center"/>
                                <TextBlock Text="SYN Flood" FontSize="10" Foreground="#78909C" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding HttpsServerGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:HttpsServerGroup}">
                                    <Border Style="{StaticResource AlertCardStyle}" BorderBrush="{Binding StateColor}" Margin="0,0,0,4">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding StateColor}" Opacity="0.06"/>
                                        </Border.Background>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="28"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding StateIcon}" FontSize="14" VerticalAlignment="Top" Margin="0,2,0,0"/>
                                            <StackPanel Grid.Column="1" Margin="6,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding DstIp}" FontWeight="SemiBold" FontSize="12" Foreground="White"/>
                                                    <TextBlock Text="→ :443" FontSize="11" Foreground="#78909C" Margin="4,0,0,0"
                                                               ToolTip="External client connecting to our service on port 443"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding ConnectionsLabel}" FontSize="10" Foreground="#B0BEC5" Margin="0,2,0,0"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <TextBlock Text="{Binding TotalPackets, StringFormat='📦 {0}'}" FontSize="10" Foreground="#546E7A" Margin="0,0,12,0"/>
                                                    <TextBlock Text="{Binding TotalBytes, StringFormat='📊 {0:N0} bytes'}" FontSize="10" Foreground="#546E7A"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{Binding TimeRange}" FontSize="9" Foreground="#546E7A" VerticalAlignment="Top"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
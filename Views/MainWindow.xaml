<Window x:Class="DPI_Home.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:models="clr-namespace:DPI_Home.Models"
        xmlns:viewmodels="clr-namespace:DPI_Home.ViewModels"
        Title="DPI Home — Анализатор трафика MikroTik"
        Height="900" Width="1400"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A2E"
        TextElement.Foreground="White"
        FontFamily="Segoe UI, sans-serif">

    <Window.DataContext>
        <viewmodels:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="AlertCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#16213E"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2A2A4A"/>
        </Style>
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#90CAF9"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== HEADER ===== -->
        <Border Grid.Row="0" Background="#0F3460" Padding="16,12" BorderBrush="#1A5276" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🛡️" FontSize="28" Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock Text="DPI Home" FontSize="22" FontWeight="Bold" Foreground="#E8EAF6"/>
                        <TextBlock Text="Анализатор трафика MikroTik" FontSize="12" Foreground="#90CAF9" Margin="0,-2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,0" VerticalAlignment="Center">
                        <Ellipse Width="10" Height="10" Fill="{Binding StatusColor}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ConnectionStatus}" FontSize="13" Foreground="#B0BEC5" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Background="#1A1A2E" CornerRadius="6" BorderBrush="#2A2A4A" BorderThickness="1" Padding="8,4" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Порт:" FontSize="12" Foreground="#78909C" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding ListenPort}" FontSize="13" Foreground="#64B5F6" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Button Command="{Binding StartCommand}" Width="140" Height="36"
                            materialDesign:ButtonAssist.CornerRadius="8" FontWeight="SemiBold" FontSize="13">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                <Setter Property="Background" Value="#4CAF50"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Content" Value="▶ Старт"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Background" Value="#F44336"/>
                                        <Setter Property="Content" Value="■ Стоп"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Rectangle Width="1" Fill="#2A2A4A" Margin="12,0"/>

                    <Border Background="#1A1A2E" CornerRadius="6" BorderBrush="#2A2A4A" BorderThickness="1" Padding="8,4" Margin="12,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="MikroTik:" FontSize="12" Foreground="#78909C" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox Text="{Binding MikrotikHost}" Width="90" FontSize="12"
                                     Background="#0D1B2A" Foreground="White" BorderThickness="0"
                                     materialDesign:HintAssist.Hint="IP"/>
                            <TextBlock Text=":" FontSize="12" Foreground="#78909C" VerticalAlignment="Center" Margin="2,0"/>
                            <TextBox Text="{Binding MikrotikUser}" Width="50" FontSize="12"
                                     Background="#0D1B2A" Foreground="White" BorderThickness="0"
                                     materialDesign:HintAssist.Hint="user" Margin="2,0"/>
                            <TextBox Text="{Binding MikrotikPassword}" Width="70" FontSize="12"
                                     Background="#0D1B2A" Foreground="White" BorderThickness="0"
                                     materialDesign:HintAssist.Hint="pass" Margin="2,0"/>
                            <Button Command="{Binding ConnectMikrotikCommand}"
                                    Content="🔗" Width="32" Height="24" FontSize="14"
                                    Background="#37474F" Foreground="White"
                                    materialDesign:ButtonAssist.CornerRadius="4"
                                    Margin="4,0,0,0" Cursor="Hand"
                                    ToolTip="Подключиться к MikroTik API"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#1A1A2E" CornerRadius="6" BorderBrush="#2A2A4A" BorderThickness="1" Padding="8,4" Margin="8,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="WAN IP:" FontSize="12" Foreground="#78909C" VerticalAlignment="Center" Margin="0,0,6,0"
                                       ToolTip="Публичный адрес роутера. Без него входящие атаки на ваш WAN-IP не детектируются (Direction=Unknown). Определяется автоматически при подключении к MikroTik (IP Cloud) либо вводится вручную."/>
                            <TextBox Text="{Binding WanIp, UpdateSourceTrigger=PropertyChanged}" Width="100" FontSize="12"
                                     Background="#0D1B2A" Foreground="White" BorderThickness="0"
                                     materialDesign:HintAssist.Hint="напр. 203.0.113.7"/>
                            <Button Command="{Binding ApplyWanIpCommand}"
                                    Content="✔" Width="28" Height="24" FontSize="13"
                                    Background="#37474F" Foreground="#66BB6A"
                                    materialDesign:ButtonAssist.CornerRadius="4"
                                    Margin="4,0,0,0" Cursor="Hand"
                                    ToolTip="Применить WAN-IP вручную"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== STATS ===== -->
        <Border Grid.Row="1" Background="#16213E" Padding="16,12" BorderBrush="#1A1A2E" BorderThickness="0,0,0,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource StatCardStyle}" Margin="0,0,4,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="📦" FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Stats.TotalPackets, StringFormat={}{0:N0}}" FontSize="20" FontWeight="Bold" Foreground="#64B5F6" HorizontalAlignment="Center"/>
                        <TextBlock Text="Пакетов" FontSize="10" Foreground="#78909C" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource StatCardStyle}" Margin="4,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="💀" FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Stats.AlertsCritical}" FontSize="20" FontWeight="Bold" Foreground="#F44336" HorizontalAlignment="Center"/>
                        <TextBlock Text="Критические" FontSize="10" Foreground="#78909C" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource StatCardStyle}" Margin="4,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="🔴" FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Stats.AlertsHigh}" FontSize="20" FontWeight="Bold" Foreground="#FF5722" HorizontalAlignment="Center"/>
                        <TextBlock Text="Высокие" FontSize="10" Foreground="#78909C" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Style="{StaticResource StatCardStyle}" Margin="4,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="⚡" FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Stats.AlertsMedium}" FontSize="20" FontWeight="Bold" Foreground="#FF9800" HorizontalAlignment="Center"/>
                        <TextBlock Text="Средние" FontSize="10" Foreground="#78909C" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="4" Style="{StaticResource StatCardStyle}" Margin="4,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="🚨" FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Stats.AlertsToday}" FontSize="20" FontWeight="Bold" Foreground="#E040FB" HorizontalAlignment="Center"/>
                        <TextBlock Text="Алертов" FontSize="10" Foreground="#78909C" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="5" Style="{StaticResource StatCardStyle}" Margin="4,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="🔒" FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding HttpsServerCount}" FontSize="20" FontWeight="Bold" Foreground="#66BB6A" HorizontalAlignment="Center"/>
                        <TextBlock Text="HTTPS серверов" FontSize="10" Foreground="#78909C" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="6" Style="{StaticResource StatCardStyle}" Margin="4,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="✅" FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding HttpsEstablishedCount}" FontSize="20" FontWeight="Bold" Foreground="#4CAF50" HorizontalAlignment="Center"/>
                        <TextBlock Text="Установлено" FontSize="10" Foreground="#78909C" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="7" Style="{StaticResource StatCardStyle}" Margin="4,0,0,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock FontSize="18" HorizontalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="⏹️"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Text" Value="🟢"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="Статус" FontSize="10" Foreground="#78909C" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding ConnectionStatus}" FontSize="10" Foreground="#B0BEC5" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ===== MAIN CONTENT ===== -->
        <Grid Grid.Row="2" Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="400"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Alert Log -->
            <Border Grid.Column="0" Background="#1A1A2E" Margin="0,0,1,0">
                <Grid Margin="16,12,8,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="📋 Лента событий" Style="{StaticResource SectionHeaderStyle}" Margin="0"/>
                        <Button Grid.Column="1" Command="{Binding ClearLogCommand}"
                                Content="🗑 Очистить" FontSize="11" Height="28" Width="90"
                                Background="#37474F" Foreground="#B0BEC5"
                                BorderBrush="#546E7A" BorderThickness="1"
                                materialDesign:ButtonAssist.CornerRadius="6" Cursor="Hand"/>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding AlertGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:AlertGroup}">
                                    <Border Style="{StaticResource AlertCardStyle}" BorderBrush="{Binding LevelColor}">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding LevelColor}" Opacity="0.08"/>
                                        </Border.Background>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="36"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="{Binding LevelIcon}" FontSize="20" VerticalAlignment="Top" Margin="0,2,0,0"/>

                                            <StackPanel Grid.Column="1" Margin="8,0">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <TextBlock Text="{Binding SrcIp}" FontWeight="SemiBold" FontSize="14" Foreground="White"/>
                                                    <Border Background="{Binding LevelColor}" CornerRadius="4" Padding="6,1" Margin="8,0,0,0">
                                                        <TextBlock Text="{Binding MaxLevel}" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                                    </Border>
                                                    <Border Background="#37474F" CornerRadius="4" Padding="6,1" Margin="4,0,0,0">
                                                        <TextBlock Text="{Binding CountLabel}" FontSize="10" Foreground="#B0BEC5"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding AttackTypes}" FontSize="12" Foreground="#B0BEC5" TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" VerticalAlignment="Top" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding TimeRange}" FontSize="10" Foreground="#546E7A" TextAlignment="Right"/>
                                                <Button Command="{Binding DataContext.BlockIpCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding SrcIp}"
                                                        Content="🚫 Block" Width="60" Height="22" FontSize="9"
                                                        Background="#37474F" Foreground="#FF5722"
                                                        BorderThickness="0" Cursor="Hand" Margin="0,4,0,0"
                                                        materialDesign:ButtonAssist.CornerRadius="4"
                                                        ToolTip="Заблокировать этот IP на MikroTik на 24ч"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- RIGHT: HTTPS Connections -->
            <Border Grid.Column="1" Background="#16213E" BorderBrush="#1A1A2E" BorderThickness="1,0,0,0">
                <Grid Margin="12,12,16,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="🔒 HTTPS соединения (порт 443)" Style="{StaticResource SectionHeaderStyle}"/>

                    <Border Grid.Row="1" Background="#0D1B2A" CornerRadius="8" Padding="10" Margin="0,0,0,8" BorderBrush="#2A2A4A" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding HttpsServerCount}" FontSize="18" FontWeight="Bold" Foreground="#66BB6A" HorizontalAlignment="Center"/>
                                <TextBlock Text="Серверов" FontSize="10" Foreground="#78909C" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding HttpsEstablishedCount}" FontSize="18" FontWeight="Bold" Foreground="#4CAF50" HorizontalAlignment="Center"/>
                                <TextBlock Text="Установлено" FontSize="10" Foreground="#78909C" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding HttpsSynFloodCount}" FontSize="18" FontWeight="Bold" Foreground="#F44336" HorizontalAlignment="Center"/>
                                <TextBlock Text="SYN Flood" FontSize="10" Foreground="#78909C" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding HttpsServerGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:HttpsServerGroup}">
                                    <Border Style="{StaticResource AlertCardStyle}" BorderBrush="{Binding StateColor}" Margin="0,0,0,4">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding StateColor}" Opacity="0.06"/>
                                        </Border.Background>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="28"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding StateIcon}" FontSize="14" VerticalAlignment="Top" Margin="0,2,0,0"/>
                                            <StackPanel Grid.Column="1" Margin="6,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding DstIp}" FontWeight="SemiBold" FontSize="12" Foreground="White"/>
                                                    <TextBlock Text=":443" FontSize="11" Foreground="#78909C" Margin="4,0,0,0"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding ConnectionsLabel}" FontSize="10" Foreground="#B0BEC5" Margin="0,2,0,0"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <TextBlock Text="{Binding TotalPackets, StringFormat='📦 {0}'}" FontSize="10" Foreground="#546E7A" Margin="0,0,12,0"/>
                                                    <TextBlock Text="{Binding TotalBytes, StringFormat='📊 {0:N0} байт'}" FontSize="10" Foreground="#546E7A"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{Binding TimeRange}" FontSize="9" Foreground="#546E7A" VerticalAlignment="Top"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
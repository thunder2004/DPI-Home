<Window x:Class="DPI_Home.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:models="clr-namespace:DPI_Home.Models"
        xmlns:viewmodels="clr-namespace:DPI_Home.ViewModels"
        mc:Ignorable="d"
        Title="DPI Home — Анализатор трафика MikroTik"
        Height="900" Width="1400"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A2E"
        TextElement.Foreground="White"
        FontFamily="Segoe UI, sans-serif">

    <Window.DataContext>
        <viewmodels:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <!-- Converters -->
        <Style x:Key="AlertCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#16213E"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2A2A4A"/>
        </Style>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#90CAF9"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== HEADER ===== -->
        <Border Grid.Row="0" Background="#0F3460" Padding="16,12" BorderBrush="#1A5276" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo / Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🛡️" FontSize="28" Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock Text="DPI Home" FontSize="22" FontWeight="Bold" Foreground="#E8EAF6"/>
                        <TextBlock Text="Анализатор трафика MikroTik" FontSize="12" Foreground="#90CAF9" Margin="0,-2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Connection controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,0" VerticalAlignment="Center">
                        <Ellipse Width="10" Height="10" Fill="{Binding StatusColor}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ConnectionStatus}" FontSize="13" Foreground="#B0BEC5" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Background="#1A1A2E" CornerRadius="6" BorderBrush="#2A2A4A" BorderThickness="1" Padding="8,4" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Хост:" FontSize="12" Foreground="#78909C" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox Text="{Binding HostAddress}" Width="130" FontSize="12"
                                     Background="#0D1B2A" Foreground="White" BorderThickness="0"
                                     materialDesign:HintAssist.Hint="192.168.105.1"/>
                            <TextBlock Text=":" FontSize="12" Foreground="#78909C" VerticalAlignment="Center" Margin="4,0"/>
                            <TextBox Text="{Binding HostPort}" Width="50" FontSize="12"
                                     Background="#0D1B2A" Foreground="White" BorderThickness="0"
                                     materialDesign:HintAssist.Hint="2000"/>
                        </StackPanel>
                    </Border>

                    <Button Command="{Binding ConnectCommand}" Width="120" Height="36"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            FontWeight="SemiBold" FontSize="13">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                <Setter Property="Background" Value="#4CAF50"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Content" Value="▶ Подключиться"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Background" Value="#F44336"/>
                                        <Setter Property="Content" Value="■ Отключиться"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== STATS DASHBOARD ===== -->
        <Border Grid.Row="1" Background="#16213E" Padding="16,12" BorderBrush="#1A1A2E" BorderThickness="0,0,0,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Stat: Packets -->
                <Border Grid.Column="0" Style="{StaticResource StatCardStyle}" Margin="0,0,6,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="📦" FontSize="20" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Stats.TotalPackets, StringFormat={}{0:N0}}" 
                                   FontSize="22" FontWeight="Bold" Foreground="#64B5F6" HorizontalAlignment="Center"/>
                        <TextBlock Text="Пакетов" FontSize="11" Foreground="#78909C" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Stat: Critical -->
                <Border Grid.Column="1" Style="{StaticResource StatCardStyle}" Margin="6,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="💀" FontSize="20" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Stats.AlertsCritical}" 
                                   FontSize="22" FontWeight="Bold" Foreground="#F44336" HorizontalAlignment="Center"/>
                        <TextBlock Text="Критические" FontSize="11" Foreground="#78909C" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Stat: High -->
                <Border Grid.Column="2" Style="{StaticResource StatCardStyle}" Margin="6,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="🔴" FontSize="20" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Stats.AlertsHigh}" 
                                   FontSize="22" FontWeight="Bold" Foreground="#FF5722" HorizontalAlignment="Center"/>
                        <TextBlock Text="Высокие" FontSize="11" Foreground="#78909C" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Stat: Medium -->
                <Border Grid.Column="3" Style="{StaticResource StatCardStyle}" Margin="6,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="⚡" FontSize="20" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Stats.AlertsMedium}" 
                                   FontSize="22" FontWeight="Bold" Foreground="#FF9800" HorizontalAlignment="Center"/>
                        <TextBlock Text="Средние" FontSize="11" Foreground="#78909C" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Stat: Total Alerts -->
                <Border Grid.Column="4" Style="{StaticResource StatCardStyle}" Margin="6,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="🚨" FontSize="20" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Stats.AlertsToday}" 
                                   FontSize="22" FontWeight="Bold" Foreground="#E040FB" HorizontalAlignment="Center"/>
                        <TextBlock Text="Всего алертов" FontSize="11" Foreground="#78909C" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Stat: Status -->
                <Border Grid.Column="5" Style="{StaticResource StatCardStyle}" Margin="6,0,0,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding IsConnected, Converter={x:Null}}" FontSize="20" HorizontalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="⏹️"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Text" Value="🟢"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="Статус" FontSize="11" Foreground="#78909C" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding ConnectionStatus}" FontSize="11" Foreground="#B0BEC5" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ===== MAIN CONTENT ===== -->
        <Grid Grid.Row="2" Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Alert List -->
            <Border Grid.Column="0" Background="#1A1A2E" Margin="0,0,1,0">
                <Grid Margin="16,12,8,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="📋 Лента событий" Style="{StaticResource SectionHeaderStyle}"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Alerts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:Alert}">
                                    <Border Style="{StaticResource AlertCardStyle}"
                                            BorderBrush="{Binding LevelColor}">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding LevelColor}" Opacity="0.08"/>
                                        </Border.Background>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="36"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Icon -->
                                            <TextBlock Grid.Column="0" Text="{Binding LevelIcon}" FontSize="20" 
                                                       VerticalAlignment="Top" Margin="0,2,0,0"/>

                                            <!-- Content -->
                                            <StackPanel Grid.Column="1" Margin="8,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14" Foreground="White"/>
                                                    <Border Background="{Binding LevelColor}" CornerRadius="4" Padding="6,1" Margin="8,0,0,0">
                                                        <TextBlock Text="{Binding Level}" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Description}" FontSize="12" Foreground="#B0BEC5" 
                                                           Margin="0,4,0,0" TextWrapping="Wrap"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock Text="{Binding SrcIp, StringFormat='📤 {0}'}" FontSize="11" Foreground="#78909C" Margin="0,0,16,0"/>
                                                    <TextBlock Text="{Binding DstIp, StringFormat='📥 {0}'}" FontSize="11" Foreground="#78909C" Margin="0,0,16,0"/>
                                                    <TextBlock Text="{Binding Protocol}" FontSize="11" Foreground="#78909C"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Time -->
                                            <TextBlock Grid.Column="2" Text="{Binding Timestamp, StringFormat='HH:mm:ss'}" 
                                                       FontSize="11" Foreground="#546E7A" VerticalAlignment="Top"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- RIGHT: Recent Alerts + Info -->
            <Border Grid.Column="1" Background="#16213E" BorderBrush="#1A1A2E" BorderThickness="1,0,0,0">
                <Grid Margin="12,12,16,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Recent alerts header -->
                    <TextBlock Grid.Row="0" Text="🔥 Последние алерты" Style="{StaticResource SectionHeaderStyle}"/>

                    <!-- Recent alerts list -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding RecentAlerts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:Alert}">
                                    <Border Style="{StaticResource AlertCardStyle}"
                                            BorderBrush="{Binding LevelColor}"
                                            Margin="0,0,0,4">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding LevelColor}" Opacity="0.06"/>
                                        </Border.Background>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="28"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="{Binding LevelIcon}" FontSize="16" VerticalAlignment="Top"/>
                                            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="12" Foreground="White"/>
                                                <TextBlock Text="{Binding Category}" FontSize="10" Foreground="#78909C"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Bottom info -->
                    <Border Grid.Row="2" Background="#0D1B2A" CornerRadius="8" Padding="12" Margin="0,8,0,0"
                            BorderBrush="#2A2A4A" BorderThickness="1">
                        <StackPanel>
                            <TextBlock FontSize="11" Foreground="#546E7A">
                                <Run Text="💡 " /><Run Text="DPI Home v1.0 — " />
                                <Run Text="Анализ трафика в реальном времени"/>
                            </TextBlock>
                            <TextBlock FontSize="10" Foreground="#37474F" Margin="0,4,0,0">
                                MikroTik Packet Sniffer → DPI → Поведенческий анализ
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
